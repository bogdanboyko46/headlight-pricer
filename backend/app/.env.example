# Anthropic API key — used by the LLM fallback flag-extraction pass.
# If unset, the extractor uses only the regex pass (which is fine for
# common phrasings but misses subtle wording).
# Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional overrides:
# DB_PATH=./data.db
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# MAX_LISTINGS_PER_SCRAPE=40
# DETAIL_FETCH_CONCURRENCY=2
# SOLD_WINDOW_DAYS=60
# MIN_COMPARABLE_SOLD=5
# SOFT_SIMILARITY_THRESHOLD=0.5
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
